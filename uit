<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UNNAMALAI INSTITUTE OF TECHNOLOGY - Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --mint-green: #A8D8D8;
            --aqua-green: #7ECCC4;
            --olive-green: #6B8E23;
            --off-white: #F5F5F0;
            --cream: #F0EBE0;
            --dark-green: #2D5F4F;
            --text-dark: #2C3E50;
            --shadow: rgba(107, 142, 35, 0.15);
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        html, body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            background: linear-gradient(135deg, var(--off-white) 0%, var(--cream) 100%);
        }

        body {
            font-family: 'Poppins', sans-serif;
            color: var(--text-dark);
            overflow-x: hidden;
        }

        /* ============ ANIMATIONS ============ */
        @keyframes engineerSlideIn {
            0% {
                opacity: 0;
                transform: translateX(-100px) rotateY(-20deg);
            }
            100% {
                opacity: 1;
                transform: translateX(0) rotateY(0);
            }
        }

        @keyframes studentSlideIn {
            0% {
                opacity: 0;
                transform: translateX(100px) rotateY(20deg);
            }
            100% {
                opacity: 1;
                transform: translateX(0) rotateY(0);
            }
        }

        @keyframes titlePulse {
            0%, 100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.02);
            }
        }

        @keyframes glowPulse {
            0%, 100% {
                box-shadow: 0 0 20px rgba(126, 204, 196, 0.3);
            }
            50% {
                box-shadow: 0 0 40px rgba(126, 204, 196, 0.6);
            }
        }

        @keyframes floatUp {
            0% {
                opacity: 0;
                transform: translateY(30px);
            }
            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes shimmer {
            0% {
                background-position: -1000px 0;
            }
            100% {
                background-position: 1000px 0;
            }
        }

        /* ============ SPLASH SCREEN ============ */
        .splash-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #A8D8D8 0%, #7ECCC4 50%, #6B8E23 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            z-index: 9999;
            animation: fadeOut 0.8s ease-in-out 3s forwards;
            overflow: hidden;
        }

        @keyframes fadeOut {
            0% {
                opacity: 1;
                visibility: visible;
            }
            100% {
                opacity: 0;
                visibility: hidden;
            }
        }

        .splash-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 60px;
            perspective: 1000px;
            width: 100%;
            height: 100%;
            padding: 60px 40px;
        }

        .splash-header {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 30px;
            animation: headerFadeIn 1.2s ease-out;
        }

        .splash-logo {
            width: 140px;
            height: 140px;
            animation: logoFloat 3s ease-in-out infinite;
            filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.3));
        }

        @keyframes logoFloat {
            0%, 100% {
                transform: translateY(0px) scale(1);
            }
            50% {
                transform: translateY(-15px) scale(1.05);
            }
        }

        @keyframes headerFadeIn {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .splash-title {
            text-align: center;
            animation: titlePulse 2s ease-in-out 0.5s infinite;
        }

        .splash-title h1 {
            font-family: 'Playfair Display', serif;
            font-size: 48px;
            color: white;
            margin-bottom: 10px;
            text-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
            letter-spacing: 2px;
            animation: textFadeIn 1.2s ease-out 0.3s forwards;
            opacity: 0;
        }

        .splash-title p {
            color: rgba(255, 255, 255, 0.95);
            font-size: 14px;
            letter-spacing: 3px;
            animation: textFadeIn 1.2s ease-out 0.6s forwards;
            opacity: 0;
        }

        @keyframes textFadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .splash-figures {
            display: flex;
            align-items: flex-end;
            justify-content: center;
            gap: 100px;
        }

        .engineer-figure {
            font-size: 100px;
            animation: engineerSlideIn 1.5s ease-out 0.4s forwards;
            filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.3));
            opacity: 0;
        }

        @keyframes engineerSlideIn {
            0% {
                opacity: 0;
                transform: translateX(-100px) translateY(50px) rotateY(-25deg) scale(0.85);
            }
            100% {
                opacity: 1;
                transform: translateX(0) translateY(0) rotateY(0) scale(1);
            }
        }

        .student-figure {
            font-size: 100px;
            animation: studentSlideIn 1.5s ease-out 0.6s forwards, studentDance 2s ease-in-out 2.1s infinite;
            filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.3));
            opacity: 0;
        }

        @keyframes studentSlideIn {
            0% {
                opacity: 0;
                transform: translateX(100px) translateY(50px) rotateY(25deg) scale(0.85);
            }
            100% {
                opacity: 1;
                transform: translateX(0) translateY(0) rotateY(0) scale(1);
            }
        }

        @keyframes studentDance {
            0%, 100% {
                transform: translateX(0) translateY(0) rotate(0deg);
            }
            25% {
                transform: translateX(-15px) translateY(-10px) rotate(-5deg);
            }
            50% {
                transform: translateX(0) translateY(-20px) rotate(0deg);
            }
            75% {
                transform: translateX(15px) translateY(-10px) rotate(5deg);
            }
        }

        /* ============ MAIN CONTAINER ============ */
        .main-container {
            width: 100%;
            height: 100vh;
            display: flex;
            flex-direction: column;
            opacity: 0;
            animation: fadeIn 0.8s ease-in-out 3s forwards;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        /* ============ NAVBAR ============ */
        .navbar {
            background: linear-gradient(90deg, var(--dark-green) 0%, var(--olive-green) 100%);
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 15px var(--shadow);
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .navbar-logo {
            width: 50px;
            height: 50px;
            filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.2));
        }

        .navbar-brand h1 {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            color: var(--off-white);
            font-weight: 700;
            letter-spacing: 1px;
        }

        .navbar-brand p {
            color: var(--mint-green);
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 2px;
        }

        .navbar-info {
            display: flex;
            gap: 30px;
            align-items: center;
        }

        .user-role {
            background: rgba(255, 255, 255, 0.1);
            padding: 8px 16px;
            border-radius: 20px;
            color: var(--mint-green);
            font-size: 12px;
            font-weight: 600;
            border: 1px solid var(--mint-green);
            backdrop-filter: blur(10px);
        }

        .logout-btn {
            background: linear-gradient(135deg, var(--aqua-green) 0%, var(--mint-green) 100%);
            border: none;
            color: var(--dark-green);
            padding: 8px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: 600;
            font-size: 12px;
            transition: var(--transition);
            box-shadow: 0 4px 15px rgba(126, 204, 196, 0.3);
        }

        .logout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(126, 204, 196, 0.5);
        }

        /* ============ CONTENT AREA ============ */
        .content {
            flex: 1;
            overflow-y: auto;
            padding: 40px;
            background: linear-gradient(to bottom, var(--off-white), var(--cream));
        }

        .content::-webkit-scrollbar {
            width: 8px;
        }

        .content::-webkit-scrollbar-track {
            background: var(--cream);
        }

        .content::-webkit-scrollbar-thumb {
            background: var(--aqua-green);
            border-radius: 4px;
        }

        /* ============ SCREENS ============ */
        .screen {
            display: none;
            animation: floatUp 0.6s ease-out;
        }

        .screen.active {
            display: block;
        }

        /* Welcome Screen */
        .welcome-screen {
            text-align: center;
        }

        .welcome-title {
            font-family: 'Playfair Display', serif;
            font-size: 48px;
            color: var(--dark-green);
            margin-bottom: 10px;
            letter-spacing: 2px;
        }

        .welcome-subtitle {
            color: var(--olive-green);
            font-size: 16px;
            margin-bottom: 50px;
            font-weight: 300;
            letter-spacing: 1px;
        }

        .welcome-hero {
            margin-bottom: 40px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .welcome-image {
            width: 100%;
            max-width: 600px;
            height: auto;
            border-radius: 15px;
            box-shadow: 0 10px 40px var(--shadow);
            animation: floatUp 0.8s ease-out;
        }

        .welcome-footer-image {
            margin-top: 60px;
            text-align: center;
            opacity: 0.8;
        }

        .footer-image {
            max-width: 800px;
            width: 100%;
            height: auto;
            border-radius: 15px;
            box-shadow: 0 10px 40px var(--shadow);
            animation: floatUp 1s ease-out 0.3s backwards;
            animation-fill-mode: forwards;
        }

        .role-selection {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            margin-top: 50px;
        }

        .role-card {
            background: linear-gradient(135deg, var(--off-white) 0%, var(--cream) 100%);
            border: 2px solid var(--mint-green);
            border-radius: 15px;
            padding: 40px 25px;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: 0 4px 15px var(--shadow);
            position: relative;
            overflow: hidden;
        }

        .role-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(126, 204, 196, 0.3), transparent);
            transition: left 0.5s ease;
        }

        .role-card:hover::before {
            left: 100%;
        }

        .role-card:hover {
            transform: translateY(-10px);
            border-color: var(--aqua-green);
            box-shadow: 0 15px 40px var(--shadow);
        }

        .role-icon {
            font-size: 60px;
            margin-bottom: 20px;
            display: block;
        }

        .role-name {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            color: var(--dark-green);
            margin-bottom: 10px;
            font-weight: 700;
        }

        .role-description {
            color: var(--olive-green);
            font-size: 13px;
            line-height: 1.6;
        }

        /* ============ DASHBOARD SCREENS ============ */
        .dashboard-header {
            font-family: 'Playfair Display', serif;
            font-size: 36px;
            color: var(--dark-green);
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 3px solid var(--aqua-green);
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }

        .action-card {
            background: linear-gradient(135deg, var(--off-white) 0%, var(--cream) 100%);
            border: 2px solid var(--mint-green);
            border-radius: 12px;
            padding: 30px;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: 0 4px 15px var(--shadow);
        }

        .action-card:hover {
            transform: translateY(-8px);
            border-color: var(--aqua-green);
            box-shadow: 0 12px 30px var(--shadow);
        }

        .action-icon {
            font-size: 40px;
            margin-bottom: 15px;
        }

        .action-title {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            color: var(--dark-green);
            margin-bottom: 10px;
            font-weight: 700;
        }

        .action-description {
            color: var(--olive-green);
            font-size: 13px;
            line-height: 1.6;
        }

        /* ============ MODAL ============ */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            animation: fadeIn 0.3s ease-out;
            justify-content: center;
            align-items: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: linear-gradient(135deg, var(--off-white) 0%, var(--cream) 100%);
            border-radius: 15px;
            padding: 40px;
            max-width: 600px;
            width: 90%;
            max-height: 85vh;
            overflow-y: auto;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
            position: relative;
        }

        .modal-header {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            color: var(--dark-green);
            margin-bottom: 20px;
            font-weight: 700;
        }

        .close-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            background: none;
            border: none;
            font-size: 28px;
            cursor: pointer;
            color: var(--olive-green);
            transition: var(--transition);
        }

        .close-btn:hover {
            transform: rotate(90deg);
            color: var(--dark-green);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: var(--dark-green);
            margin-bottom: 8px;
            font-size: 14px;
        }

        .form-input,
        .form-textarea,
        .form-select {
            width: 100%;
            padding: 12px;
            border: 2px solid var(--mint-green);
            border-radius: 8px;
            font-family: 'Poppins', sans-serif;
            font-size: 14px;
            transition: var(--transition);
            background: rgba(255, 255, 255, 0.7);
        }

        .form-input:focus,
        .form-textarea:focus,
        .form-select:focus {
            outline: none;
            border-color: var(--aqua-green);
            box-shadow: 0 0 0 3px rgba(126, 204, 196, 0.2);
            background: white;
        }

        .form-textarea {
            resize: vertical;
            min-height: 100px;
        }

        .file-input-wrapper {
            position: relative;
            display: inline-block;
            width: 100%;
        }

        .file-input-label {
            display: block;
            background: linear-gradient(135deg, var(--mint-green) 0%, var(--aqua-green) 100%);
            color: white;
            padding: 12px;
            border-radius: 8px;
            text-align: center;
            cursor: pointer;
            font-weight: 600;
            transition: var(--transition);
        }

        .file-input-label:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(126, 204, 196, 0.4);
        }

        .file-input {
            display: none;
        }

        .file-name {
            margin-top: 8px;
            color: var(--olive-green);
            font-size: 13px;
        }

        .btn-submit,
        .btn-secondary {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: var(--transition);
            margin-top: 15px;
        }

        .btn-submit {
            background: linear-gradient(135deg, var(--aqua-green) 0%, var(--mint-green) 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(126, 204, 196, 0.3);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(126, 204, 196, 0.5);
        }

        .btn-secondary {
            background: rgba(107, 142, 35, 0.1);
            color: var(--olive-green);
            border: 2px solid var(--olive-green);
        }

        .btn-secondary:hover {
            background: var(--olive-green);
            color: white;
        }

        .btn-back {
            background: linear-gradient(135deg, var(--mint-green) 0%, var(--aqua-green) 100%);
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 20px;
            cursor: pointer;
            font-weight: 600;
            font-size: 13px;
            transition: var(--transition);
            margin-bottom: 20px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-back:hover {
            transform: translateX(-3px);
        }

        /* ============ STUDENTS DASHBOARD ============ */
        .dashboard-section {
            margin-bottom: 40px;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            color: var(--dark-green);
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--mint-green);
            font-weight: 700;
        }

        /* ============ PUBLIC/PRIVATE TABS ============ */
        .institution-tabs {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
        }

        .tab-btn {
            padding: 12px 25px;
            border: 2px solid var(--mint-green);
            background: var(--cream);
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            color: var(--olive-green);
            transition: var(--transition);
            font-family: 'Poppins', sans-serif;
        }

        .tab-btn.active {
            background: linear-gradient(135deg, var(--aqua-green) 0%, var(--mint-green) 100%);
            color: white;
            border-color: var(--aqua-green);
        }

        .tab-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px var(--shadow);
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
            animation: floatUp 0.4s ease-out;
        }

        /* ============ RESPONSIVE ============ */
        @media (max-width: 768px) {
            .splash-content {
                gap: 20px;
            }

            .engineer-figure,
            .student-figure {
                font-size: 80px;
            }

            .splash-title h1 {
                font-size: 32px;
            }

            .navbar {
                flex-direction: column;
                gap: 15px;
            }

            .navbar-info {
                flex-direction: column;
                gap: 15px;
            }

            .content {
                padding: 20px;
            }

            .welcome-title {
                font-size: 32px;
            }

            .role-selection {
                grid-template-columns: 1fr;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
            }

            .modal-content {
                width: 95%;
                padding: 25px;
            }
        }

        /* Loading Spinner */
        .spinner {
            border: 3px solid var(--mint-green);
            border-top: 3px solid var(--aqua-green);
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
            margin: 10px auto;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .success-message {
            background: linear-gradient(135deg, #A8D8D8 0%, #7ECCC4 100%);
            color: white;
            padding: 15px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-weight: 600;
            animation: floatUp 0.4s ease-out;
        }

        /* Table Styles */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 15px var(--shadow);
        }

        .data-table thead {
            background: linear-gradient(135deg, var(--olive-green) 0%, var(--dark-green) 100%);
            color: white;
        }

        .data-table th {
            padding: 15px;
            text-align: left;
            font-weight: 600;
            font-size: 13px;
        }

        .data-table td {
            padding: 12px 15px;
            border-bottom: 1px solid var(--mint-green);
            font-size: 13px;
        }

        .data-table tbody tr:hover {
            background: var(--cream);
        }

        .badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-warning {
            background: rgba(255, 152, 0, 0.2);
            color: #FF9800;
        }

        .badge-success {
            background: rgba(76, 175, 80, 0.2);
            color: #4CAF50;
        }

        .badge-danger {
            background: rgba(244, 67, 54, 0.2);
            color: #F44336;
        }

        /* ============ TABLE STYLES ============ */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        .data-table thead {
            background: linear-gradient(90deg, var(--dark-green) 0%, var(--olive-green) 100%);
            color: white;
        }

        .data-table th {
            padding: 15px;
            text-align: left;
            font-weight: 600;
            border-bottom: 2px solid var(--aqua-green);
        }

        .data-table td {
            padding: 12px 15px;
            border-bottom: 1px solid #e0e0e0;
            color: var(--text-dark);
        }

        .data-table tbody tr {
            transition: var(--transition);
        }

        .data-table tbody tr:hover {
            background: rgba(168, 216, 216, 0.3);
        }

        .data-table tbody tr:last-child td {
            border-bottom: none;
        }

        /* ============ ANALYTICS STYLES ============ */
        .analytics-container {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .analytics-section {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
