            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .complaint-id {
            font-weight: 700;
            color: var(--dark-green);
            font-size: 14px;
        }

        .complaint-status {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .status-pending {
            background: rgba(255, 152, 0, 0.2);
            color: #FF9800;
        }

        .status-resolved {
            background: rgba(76, 175, 80, 0.2);
            color: #4CAF50;
        }

        .status-inprogress {
            background: rgba(33, 150, 243, 0.2);
            color: #2196F3;
        }

        .complaint-details {
            font-size: 13px;
            color: var(--text-dark);
            line-height: 1.5;
        }

        .complaint-date {
            font-size: 11px;
            color: #999;
            margin-top: 8px;
        }

