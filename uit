        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        // Screen navigation
        function selectRole(role) {
            const screenMap = {
                'student': 'studentDashboard',
                'teacher': 'teacherDashboard',
                'hod': 'hodDashboard',
                'incharge': 'inchargeDashboard',
                'principal': 'principalDashboard'
            };

            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(screenMap[role]).classList.add('active');

            const roles = {
                'student': 'Student Dashboard',
                'teacher': 'Teacher Dashboard',
                'hod': 'HOD Dashboard',
                'incharge': 'In-Charge Dashboard',
                'principal': 'Principal Dashboard'
            };
            
            document.getElementById('userRole').textContent = roles[role];
        }

        function goBack() {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById('welcomeScreen').classList.add('active');
            document.getElementById('userRole').textContent = 'Welcome';
        }

        function logout() {
            if (confirm('Are you sure you want to logout?')) {
                goBack();
            }
        }

        // Tab switching
        function switchTab(btn, tabId) {
            const parent = btn.parentElement;
            parent.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const tabContainer = btn.parentElement.nextElementSibling;
            const allTabs = tabContainer.parentElement.querySelectorAll('.tab-content');
            allTabs.forEach(tab => tab.classList.remove('active'));
            
            document.getElementById(tabId).classList.add('active');
        }

        // File input handling
        function showFileName(input) {
            const fileName = input.files.length > 0 
                ? `✓ ${input.files.length} file(s) selected`
                : '';
            
            const fileNameDiv = input.parentElement.parentElement.querySelector('.file-name');
            if (fileNameDiv) {
                fileNameDiv.textContent = fileName;
            }
        }

        // Form submission
        function submitForm(event, formType) {
            event.preventDefault();
            
            // Get form data
            const form = event.target;
            const formData = new FormData(form);
            
            // Show success message
            alert(`✓ ${formType.replace(/([A-Z])/g, ' $1').trim()} submitted successfully!\n\nYour request has been recorded and appropriate staff will be notified.`);
            
            // Reset form and close modal
            form.reset();
            const modal = form.closest('.modal');
            modal.classList.remove('active');
        }

        // Close modal when clicking outside
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    modal.classList.remove('active');
                }
            });
        });

        // Keyboard shortcut - ESC to close modal
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                document.querySelectorAll('.modal').forEach(m => m.classList.remove('active'));
            }
        });
    </script>
